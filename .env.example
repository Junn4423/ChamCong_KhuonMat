# ERP Database Configuration
ERP_HOST=192.168.1.82
ERP_PORT=3306
ERP_USER=faceuser
ERP_PASSWORD=THU@1982
ERP_DATABASE=erp_sofv4_0

# ERP Documents Database Configuration
ERP_DOCS_HOST=192.168.1.82
ERP_DOCS_PORT=3306
ERP_DOCS_USER=faceuser
ERP_DOCS_PASSWORD=THU@1982
ERP_DOCS_DATABASE=erp_sof_documents_v4_0
MYSQL_USE_PURE=true

# Performance Tuning
SKIP_FRAMES=8
RESIZE_FACTOR=0.2
FPS_LIMIT=30
DETECTION_WIDTH=1280

# Intel CPU Optimization (OpenVINO)
# Set number of threads equal to your CPU cores for best performance
OMP_NUM_THREADS=4
MKL_NUM_THREADS=4
# Enable OpenVINO model caching for faster startup
OPENVINO_CACHE_DIR=./openvino_cache
# Use ONNX anti-spoofing models for better Intel CPU performance
USE_ONNX_ANTISPOOF=true

# Motion Detection
MOTION_THRESHOLD=60
MOTION_MIN_AREA=2000

# Flask Environment
FLASK_ENV=production

# Internal admin login mode
INTERNAL_ADMIN_USERNAME=admin
INTERNAL_ADMIN_PASSWORD=1

# ERP HTTP Service Configuration
ERP_FETCH_MODE=http_service
ERP_HTTP_SERVICE_URL=http://192.168.1.20/erpdung-hao/services/erpv1/services.sof.vn/index.php
ERP_HTTP_LOGIN_URL=http://192.168.1.20/erpdung-hao/services/erpv1/login.sof.vn/index.php
ERP_HTTP_TIMEOUT=10
ERP_HTTP_IMAGE_COLUMN=lv008
ERP_HTTP_TOKEN_IMAGE_MODE=test
ERP_HTTP_TOKEN_IMAGE_PROD_BASE_URL=https://sof.com.vn/loadimage
ERP_HTTP_TOKEN_IMAGE_TEST_BASE_URL=http://192.168.1.87/token
ERP_HTTP_TOKEN_REGISTER_URL=http://192.168.1.87/createtoken/index.php
ERP_HTTP_TOKEN_REGISTER_USERNAME=admin
ERP_HTTP_TOKEN_REGISTER_API_TOKEN=ABC
ERP_HTTP_TOKEN_COLUMN=lv007
ERP_HTTP_SOF_DEV_TOKEN=34234324324sdfsfofsehweorio32432432sfshh3effds2343243244
ERP_HTTP_TYPE_CODE=CHAMCONG
ERP_HTTP_DEVICE_TYPE=web

# CouchDB Direct Login (lv_lv0066:{username})
ERP_COUCHDB_HOST=192.168.1.20
ERP_COUCHDB_PORT=5984
ERP_COUCHDB_DB=couchdb
ERP_COUCHDB_DISPATCHER_DB=couchdb
ERP_COUCHDB_ROUTE_DOC_PREFIX=dispatcher:prefix:
# Deprecated (routing now uses prefix before the first dot: prefix.username)
ERP_COUCHDB_ROUTE_PREFIX_LENGTH=0
ERP_COUCHDB_USER_TABLE=lv_lv0066
ERP_COUCHDB_USER=
ERP_COUCHDB_PASSWORD=
ERP_COUCHDB_LOG_DOC_ID=logs

# Last-resort dispatcher fallback (when prefix cannot be resolved on primary CouchDB)
ERP_COUCHDB_FALLBACK_HOST=192.168.1.81
ERP_COUCHDB_FALLBACK_PORT=5984
ERP_COUCHDB_FALLBACK_DISPATCHER_DB=couchdb
# Optional: set if fallback CouchDB uses different credentials
ERP_COUCHDB_FALLBACK_USER=
ERP_COUCHDB_FALLBACK_PASSWORD=
